+class LongcatFlashNgramEmbedding(nn.Module):
+    """N-gram over-embedding for LongCat-2.0 models."""
+
+    def __init__(self, config):
+        super().__init__()
+        self.use_ngram = getattr(config, 'use_ngram_embedding', False)
+        if not self.use_ngram:
+            return
+
+        self.vocab_size = config.vocab_size
+        self.hidden_size = config.hidden_size
+        self.ngram_m = getattr(config, 'ngram_embedding_m', 0)
+        self.ngram_n = getattr(config, 'ngram_embedding_n', 1)
+        self.ngram_k = getattr(config, 'ngram_embedding_k', 1)
+
+        # N-gram consists of (n-1)*k components
+        self.n_grams = (self.ngram_n - 1) * self.ngram_k
+        oe_hidden_dim = self.hidden_size // self.n_grams
+
+        # Create embedding tables for each n-gram component
+        # Sizes follow the formula: m + 2*i + 1 for i in range(n_grams)
+        self.oe_embedders = nn.ModuleList([
+            nn.Embedding(self.ngram_m + 2 * i + 1, oe_hidden_dim)
+            for i in range(self.n_grams)
+        ])
+
+        # Projection matrices to map back to full hidden_size
+        self.oe_projections = nn.ParameterList([
+            nn.Parameter(torch.empty(oe_hidden_dim, self.hidden_size))
+            for _ in range(self.n_grams)
+        ])
+
+        # Precompute hash parameters
+        self.register_buffer('ngram_mods', torch.tensor([
+            self.ngram_m + 2 * i + 1 for i in range(self.n_grams)
+        ], dtype=torch.int64))
+
+    def _compute_ngram_ids(self, input_ids):
+        """Simplified n-gram ID computation for calibration (no CUDA kernel needed)."""
+        batch_size, seq_len = input_ids.shape
+        device = input_ids.device
+
+        # For calibration, use a simplified hashing scheme
+        # This won't be perfect but good enough for activation statistics
+        ngram_ids = []
+        for i in range(self.n_grams):
+            # Hash based on position and previous tokens
+            offset = (i // self.ngram_k) + 1
+            if seq_len > offset:
+                # Simple hash: combine current and previous tokens
+                prev_ids = F.pad(input_ids[:, :-offset], (offset, 0), value=0)
+                combined = (input_ids + prev_ids * self.vocab_size) % self.ngram_mods[i]
+            else:
+                combined = input_ids % self.ngram_mods[i]
+            ngram_ids.append(combined)
+
+        return torch.stack(ngram_ids, dim=1)  # [batch, n_grams, seq_len]
+
+    def forward(self, input_ids, base_embeds):
+        """
+        Args:
+            input_ids: [batch, seq_len]
+            base_embeds: [batch, seq_len, hidden_size] from base embedding
+        Returns:
+            Combined embeddings with n-gram components averaged in
+        """
+        if not self.use_ngram:
+            return base_embeds
+
+        # Compute n-gram IDs
+        ngram_ids = self._compute_ngram_ids(input_ids)  # [batch, n_grams, seq_len]
+
+        # Get n-gram embeddings and project
+        ngram_embeds = []
+        for i in range(self.n_grams):
+            # Embed: [batch, seq_len, oe_hidden_dim]
+            embed = self.oe_embedders[i](ngram_ids[:, i, :])
+            # Project: [batch, seq_len, hidden_size]
+            projected = torch.matmul(embed, self.oe_projections[i])
+            ngram_embeds.append(projected)
+
+        # Stack and average with base embedding
+        all_embeds = torch.stack([base_embeds] + ngram_embeds, dim=0)  # [n_grams+1, batch, seq_len, hidden]
+        return all_embeds.mean(dim=0)
+
+    def load_state_dict(self, state_dict, strict=True):
+        """Custom loading to handle oe_embed_* naming from checkpoint."""
+        # Remap oe_embed_tokens{i}.weight -> oe_embedders.{i}.weight
+        # Remap oe_embed_proj{i}.weight -> oe_projections.{i} (transpose needed)
+        new_state_dict = {}
+        for key, value in state_dict.items():
+            if 'oe_embed_tokens' in key:
+                # Extract index
+                idx = int(key.split('oe_embed_tokens')[1].split('.')[0])
+                new_key = f'oe_embedders.{idx}.weight'
+                new_state_dict[new_key] = value
+            elif 'oe_embed_proj' in key:
+                idx = int(key.split('oe_embed_proj')[1].split('.')[0])
+                new_key = f'oe_projections.{idx}'
+                # Transpose: checkpoint has [hidden, oe_hidden], we need [oe_hidden, hidden]
+                new_state_dict[new_key] = value.t()
+            else:
+                new_state_dict[key] = value
+
+        return super().load_state_dict(new_state_dict, strict=strict)
+
+
