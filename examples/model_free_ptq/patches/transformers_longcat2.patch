     def forward(self, hidden_states):
         orig_shape = hidden_states.shape
+        input_dtype = hidden_states.dtype
         topk_weights, topk_indices = self.router(hidden_states)
         hidden_states = hidden_states.view(-1, hidden_states.shape[-1])
-        hidden_states = self.experts(hidden_states, topk_indices, topk_weights).view(*orig_shape)
-        return hidden_states
+
+        num_routed = self.config.n_routed_experts
+        identity_mask = (topk_indices >= num_routed).to(hidden_states.dtype)
+
+        # Identity/zero experts: contribution is weight * input (pass-through)
+        identity_contribution = (topk_weights * identity_mask).sum(dim=-1, keepdim=True) * hidden_states
+
+        # Clamp indices to routed range and zero out identity expert weights
+        routed_indices = topk_indices.clamp(max=num_routed - 1)
+        routed_weights = topk_weights * (1.0 - identity_mask)
+
+        result = self.experts(hidden_states, routed_indices, routed_weights) + identity_contribution
+        return result.to(input_dtype).view(*orig_shape)
 
 
