+@auto_docstring(custom_intro="N-gram over-embedding for LongCat-2.0 models.")
+class LongcatFlashNgramEmbedding(nn.Module):
+    """N-gram over-embedding for LongCat-2.0 models."""
+
+    def __init__(self, config):
+        super().__init__()
+        self.use_ngram = getattr(config, 'use_ngram_embedding', False)
+        if not self.use_ngram:
+            return
+
+        self.vocab_size = config.vocab_size
+        self.hidden_size = config.hidden_size
+        self.ngram_m = getattr(config, 'ngram_embedding_m', 0)
+        self.ngram_n = getattr(config, 'ngram_embedding_n', 1)
+        self.ngram_k = getattr(config, 'ngram_embedding_k', 1)
+
+        # N-gram consists of (n-1)*k components
+        self.n_grams = (self.ngram_n - 1) * self.ngram_k
+        oe_hidden_dim = self.hidden_size // self.n_grams
+
+        # Create embedding tables for each n-gram component
+        self.oe_embedders = nn.ModuleList([
+            nn.Embedding(self.ngram_m + 2 * i + 1, oe_hidden_dim)
+            for i in range(self.n_grams)
+        ])
+
+        # Projection matrices (stored as [hidden_size, oe_hidden_dim] to match checkpoint layout)
+        self.oe_projections = nn.ParameterList([
+            nn.Parameter(torch.empty(self.hidden_size, oe_hidden_dim))
+            for _ in range(self.n_grams)
+        ])
+
+        # Precompute hash parameters (non-persistent — derived from config, not checkpoint)
+        self.register_buffer('ngram_mods', torch.tensor([
+            self.ngram_m + 2 * i + 1 for i in range(self.n_grams)
+        ], dtype=torch.int64), persistent=False)
+
+    def _compute_ngram_ids(self, input_ids):
+        """Simplified n-gram ID computation for calibration."""
+        batch_size, seq_len = input_ids.shape
+        ngram_ids = []
+        for i in range(self.n_grams):
+            offset = (i // self.ngram_k) + 1
+            if seq_len > offset:
+                prev_ids = F.pad(input_ids[:, :-offset], (offset, 0), value=0)
+                combined = (input_ids + prev_ids * self.vocab_size) % self.ngram_mods[i]
+            else:
+                combined = input_ids % self.ngram_mods[i]
+            ngram_ids.append(combined)
+        return torch.stack(ngram_ids, dim=1)
+
+    def forward(self, input_ids, base_embeds):
+        if not self.use_ngram:
+            return base_embeds
+
+        ngram_ids = self._compute_ngram_ids(input_ids)
+        ngram_embeds = []
+        for i in range(self.n_grams):
+            embed = self.oe_embedders[i](ngram_ids[:, i, :])
+            projected = torch.matmul(embed, self.oe_projections[i].t())
+            ngram_embeds.append(projected)
+
+        all_embeds = torch.stack([base_embeds] + ngram_embeds, dim=0)
+        return all_embeds.mean(dim=0)
+
+
